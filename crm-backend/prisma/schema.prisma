// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserRole {
  Master
  Vendor
}

enum ProductType {
  rooftop
  pump
  Contact_Inquiry
}

enum PipelineStage {
  New_Lead
  Verified_Lead
  Qualified
  Site_Survey_Scheduled
  Proposal_Sent
  Negotiation
  Closed_Won
  Closed_Lost
}

enum LeadScoreStatus {
  Hot
  Warm
  Cold
}


// --- MODELS ---

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         UserRole  @default(Vendor)
  country      String?
  state        String?
  district     String?
  profileImage String?
  resetToken   String?   @unique

  assignedLeads Lead[] @relation("VendorLeads")
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // This attribute tells Prisma to manage this field automatically
}

model Lead {
  id           String   @id @default(cuid())
  productType  ProductType
  name         String?
  email        String?
  phone        String?
  otpVerified  Boolean  @default(false)

  customFields Json @default("{}")
  
  source       String?

  pipelineStage PipelineStage @default(New_Lead)
  score         Int           @default(30)

  scoreStatus   LeadScoreStatus @default(Cold)

  // --- Manual Workflow Fields ---
  fatherName      String?
  district        String?
  tehsil          String?
  village         String?
  hp              String?
  connectionType  String?
  
  approvalStatus  ApprovalStatus?
  paymentStatus   PaymentStatus?
  allotmentStatus AllotmentStatus?
  surveyStatus    SurveyStatus?
  ntpStatus       NtpStatus?
  aifStatus       AifStatus?
  cifStatus       Boolean?
  workStatus      WorkStatus?
  
  bankAccountOpen Boolean?
  meterSerialNo   String?
  panelSerialNo   String?
  // Structure Image & Customer Image will be stored in 'documents' relation or customFields if specific URLs needed.
  // We can use the generic 'documents' relation for "Structure Image", "Passbook", etc.

  assignedTo        User?     @relation("VendorLeads", fields: [assignedVendorId], references: [id])
  assignedVendorId  String?

  documents   Document[]
  activityLog Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // This attribute tells Prisma to manage this field automatically
}

model Document {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String   @default("application/octet-stream")
  data      Bytes
  size      Int      @default(0)
  lead      Lead     @relation(fields: [leadId], references: [id])
  leadId    String
  uploadedAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  user      String?
  notes     String?
  lead      Lead     @relation(fields: [leadId], references: [id])
  leadId    String
  timestamp DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid()) // Added a default value generator
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // INFO, SUCCESS, WARNING, ERROR
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// --- NEW ENUMS for Manual Workflow ---

enum ApprovalStatus {
  Approved
  Rejected
  Discom_Pending
}

enum PaymentStatus {
  Complete
  Hold
  Payment_Slip_Uploaded
  Other
}

enum AllotmentStatus {
  Received
  Pending
}

enum SurveyStatus {
  Pending
  Completed
}

enum NtpStatus {
  Received
  Not_Received
}

enum AifStatus {
  Done
  Pending
}

enum WorkStatus {
  Pending
  Material_Dispatched
  Work_Complete
}